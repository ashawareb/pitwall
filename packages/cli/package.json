{
  "name": "pitwall",
  "version": "0.1.0",
  "description": "Local web app for reviewing Claude Code sessions.",
  "type": "module",
  "bin": {
    "pitwall": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude",
    "claude-code",
    "code-review",
    "ai-review",
    "agent-review",
    "pitwall"
  ],
  "author": "Abdul Shawareb",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ashawareb/pitwall.git"
  },
  "homepage": "https://github.com/ashawareb/pitwall#readme",
  "bugs": {
    "url": "https://github.com/ashawareb/pitwall/issues"
  },
  "scripts": {
    "build": "tsup && node scripts/copy-static.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "fastify": "^4.28.1",
    "open": "^10.1.0",
    "pino-pretty": "^11.2.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@pitwall/parser": "workspace:*",
    "@pitwall/server": "workspace:*",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
